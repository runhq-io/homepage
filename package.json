{
  "name": "@runhq/be",
  "version": "0.1.0",
  "private": true,
  "description": "RunHQ Backend - Unified API + Dashboard",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --exclude \"node_modules/**\" --exclude \"dist/**\" --exclude \".next/**\" src/server.ts",
    "build": "pnpm --filter @runhq/server-protocol build && next build && tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env scripts/run-migration.js",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "deploy": "echo 'No deploy target configured'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@hono/node-server": "^1.19.9",
    "@neondatabase/serverless": "^0.10.4",
    "@runhq/server-protocol": "workspace:*",
    "@xyflow/react": "^12.10.0",
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "dagre": "^0.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.11.4",
    "jose": "^6.1.3",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.5",
    "next": "^16.1.6",
    "pg": "^8.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.3",
    "stripe": "^20.2.0",
    "ws": "^8.18.0",
    "xstate": "^5.18.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@types/bcryptjs": "^3.0.0",
    "@types/dagre": "^0.7.53",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.4"
}
