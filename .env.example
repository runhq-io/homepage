# =============================================================================
# RunHQ Backend (be/) - Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# For local dev, only DATABASE_URL, PORT, and JWT/auth secrets are needed.
# Email verification is auto-skipped when RESEND_API_KEY is not set.

# =============================================================================
# Database (required)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runhq

# =============================================================================
# Server (overrides system PORT env var)
# =============================================================================
PORT=9000

# =============================================================================
# JWT Secret (shared by API + WebSocket + Next.js token endpoints)
# =============================================================================
JWT_SECRET=local-dev-secret

# =============================================================================
# NextAuth
# =============================================================================
NEXTAUTH_URL=http://localhost:9000
AUTH_URL=http://localhost:9000
NEXTAUTH_SECRET=local-dev-secret
AUTH_SECRET=local-dev-secret

# =============================================================================
# OAuth Providers (optional for local dev)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# =============================================================================
# Claude API
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Stripe (Billing)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Google Analytics
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-6M20QMDDY2
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# =============================================================================
# Browserbase (Cloud Browser Service)
# =============================================================================
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=...

# =============================================================================
# Fly.io (Remote Server Deployment)
# =============================================================================
FLY_API_TOKEN=FlyV1 fm2_...
FLY_APP_NAME=runhq-servers
CLOUD_API_URL=https://console.runhq.io
SERVER_MACHINE_AUTOSTOP=suspend
SERVER_MACHINE_AUTOSTART=true
SERVER_MIN_MACHINES_RUNNING=0

# =============================================================================
# Cloudflare (Public Ports DNS + Tunnels)
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PUBLIC_PORTS_ZONE_ID=  # Zone ID for public ports domain (falls back to CLOUDFLARE_ZONE_ID)

# =============================================================================
# OAuth
# =============================================================================
FIRST_PARTY_CLIENT_IDS=""

# =============================================================================
# Feature Flags
# =============================================================================
# Set to true or 1 to enable the workflow cron subsystem (WorkflowCronScheduler
# + POST /api/internal/cron-sync). Production deployment should set this via
# the platform (DO App Platform env vars), not hardcoded here.
# WORKFLOWS_V1=true
#
# When true, new signups must redeem an invite code (users.is_activated) before
# they can provision a workspace; the client shows an invite-code wall. Unset or
# any value other than "true" keeps signups open. Run migration 0007 before
# enabling so existing users are grandfathered.
REQUIRE_SIGNUP_INVITE=false

# =============================================================================
# Local workspace provisioning (DockerProvider)
# =============================================================================
# When running be against a local Docker daemon, "Create Server" boots a
# Docker container instead of a Fly machine. See
# docs/superpowers/specs/2026-05-04-docker-provider-local-workspaces-design.md.

# Override the default provider selection.
#   docker → use DockerProvider (local containers)
#   fly    → use FlyProvider (real Fly.io API; useful for debugging Fly issues
#            from a local backend)
# Default: 'docker' when NODE_ENV != production, 'fly' otherwise.
# LOCAL_PROVIDER=docker

# Image ref for the workspace container. Default: runhq-server:local (lazy-built).
# Override to test against a specific tag without rebuilding.
# RUNHQ_WORKSPACE_IMAGE=runhq-server:local

# Path to the runhq server source dir (containing Dockerfile) for lazy-build.
# Default: ../runhq/server (assumes be/ and runhq/ are siblings).
# RUNHQ_WORKSPACE_DOCKERFILE_DIR=/path/to/runhq/server

# Where workspace volume bind-mount dirs are created.
# Default: /app/data/local-workspaces
# RUNHQ_LOCAL_VOLUMES_DIR=/app/data/local-workspaces
