# RunHQ BE API URL (defaults to https://console.runhq.io if not set)
VITE_API_URL=https://console.runhq.io

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# The real value is NOT committed. Deployed builds inject it from the GitHub
# Actions repo secret `VITE_GA_ID` (see .github/workflows/deploy-*.yml).
# Leave blank locally to disable analytics entirely (e.g. local dev).
VITE_GA_ID=
