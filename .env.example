# =============================================================================
# Fishtank Backend (be/) - Environment Variables
# =============================================================================
# Copy to .env and fill in your values.

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fishtank

# =============================================================================
# Server
# =============================================================================
PORT=8080

# =============================================================================
# JWT Secret (shared by API + WebSocket + Next.js token endpoints)
# =============================================================================
JWT_SECRET=generate-a-random-secret-here

# =============================================================================
# OAuth Providers (NextAuth)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# NextAuth
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
AUTH_SECRET=generate-a-random-secret-here

# =============================================================================
# Claude API
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Stripe (Billing)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Google Analytics
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-6M20QMDDY2
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# =============================================================================
# Browserbase (Cloud Browser Service)
# =============================================================================
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=...

# =============================================================================
# Fly.io (Remote Server Deployment)
# =============================================================================
FLY_API_TOKEN=FlyV1 fm2_...
FLY_APP_NAME=fishtank-servers
CLOUD_API_URL=https://console.fishtank.bot
SERVER_MACHINE_AUTOSTOP=suspend
SERVER_MACHINE_AUTOSTART=true
SERVER_MIN_MACHINES_RUNNING=0
