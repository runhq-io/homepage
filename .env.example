# =============================================================================
# RunHQ Backend (be/) - Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# For local dev, only DATABASE_URL, PORT, and JWT/auth secrets are needed.
# Email verification is auto-skipped when RESEND_API_KEY is not set.

# =============================================================================
# Database (required)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runhq

# =============================================================================
# Server (overrides system PORT env var)
# =============================================================================
PORT=9000

# =============================================================================
# JWT Secret (shared by API + WebSocket + Next.js token endpoints)
# =============================================================================
JWT_SECRET=local-dev-secret

# =============================================================================
# NextAuth
# =============================================================================
NEXTAUTH_URL=http://localhost:9000
AUTH_URL=http://localhost:9000
NEXTAUTH_SECRET=local-dev-secret
AUTH_SECRET=local-dev-secret

# =============================================================================
# OAuth Providers (optional for local dev)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# =============================================================================
# Claude API
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Stripe (Billing)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Google Analytics
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-6M20QMDDY2
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# =============================================================================
# Browserbase (Cloud Browser Service)
# =============================================================================
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=...

# =============================================================================
# Fly.io (Remote Server Deployment)
# =============================================================================
FLY_API_TOKEN=FlyV1 fm2_...
FLY_APP_NAME=runhq-servers
CLOUD_API_URL=https://console.runhq.io
SERVER_MACHINE_AUTOSTOP=suspend
SERVER_MACHINE_AUTOSTART=true
SERVER_MIN_MACHINES_RUNNING=0

# =============================================================================
# Cloudflare (Public Ports DNS + Tunnels)
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PUBLIC_PORTS_ZONE_ID=  # Zone ID for public ports domain (falls back to CLOUDFLARE_ZONE_ID)
