# RunHQ BE API URL (defaults to https://console.runhq.io if not set)
VITE_API_URL=https://console.runhq.io

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
#
# This is NOT a secret — a Measurement ID ships in cleartext in every visitor's
# bundle. Deployed builds declare it as plain config in the workflows:
#   production -> G-PK433W7S1P   (.github/workflows/deploy-production.yml)
#   staging    -> none           (.github/workflows/deploy-staging.yml)
#
# `none` is the explicit opt-out: ship this build with no analytics at all.
# Leaving it BLANK is not the same thing — a production-mode build with no value
# falls back to the production property (so a forgotten var can never again
# silently black out analytics). Staging must therefore say `none`, not "".
#
# Blank is fine locally: dev/test builds are not production-mode, so they stay off.
VITE_GA_ID=
