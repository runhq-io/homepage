{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"],
      "@runhq/server-protocol": ["./packages/protocol/dist/index.d.ts"]
    }
  },
  "include": [
    "src/server.ts",
    "src/db/**/*",
    "src/api/**/*"
  ],
  "exclude": ["node_modules", ".next"]
}
